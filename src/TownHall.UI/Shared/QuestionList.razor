@inherits ComputedStateComponent<ImmutableArray<long>>
@inject IQuestions Questions

@if (State.ValueOrDefault is { IsDefault: false } indexes) {
    @if (indexes.Length == 0) {
        <MudText Typo="Typo.body2" Class="mud-text-secondary pa-2">
            @(Tab == QuestionTab.Resolved ? "Nothing resolved yet." : "No questions yet — ask the first one!")
        </MudText>
    }
    @foreach (var index in indexes) {
        <QuestionCard @key="@index" RoomId="@RoomId" Index="@index" IsOwner="@IsOwner" IsLive="@IsLive" IsEnded="@IsEnded" />
    }
}
else {
    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
}

@code {
    [Parameter, EditorRequired] public string RoomId { get; set; } = "";
    [Parameter] public QuestionTab Tab { get; set; }
    [Parameter] public bool IsOwner { get; set; }
    [Parameter] public bool IsLive { get; set; }
    [Parameter] public bool IsEnded { get; set; }

    protected override async Task<ImmutableArray<long>> ComputeState(CancellationToken cancellationToken)
    {
        return Tab switch {
            QuestionTab.Top => await Questions.ListTopOpen(Session, RoomId, 50, cancellationToken),
            QuestionTab.Recent => await Questions.ListOpen(Session, RoomId, cancellationToken),
            _ => await Questions.ListResolved(Session, RoomId, cancellationToken),
        };
    }
}
