@inherits ComputedStateComponent<UserFull?>
@inject IUsers Users
@inject IAuth Auth
@inject TownHall.UI.Services.PasskeyClient Passkey
@inject ISnackbar Snackbar

@{
    var user = State.ValueOrDefault;
}
@if (user is { } signedIn) {
    @if (_isEditing) {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
            <MudTextField @bind-Value="_editedName" Immediate="true" Margin="Margin.Dense"
                          Variant="Variant.Outlined" MaxLength="30" Style="width: 12rem"
                          OnKeyDown="@(e => { if (e.Key == "Enter") Save(); })" />
            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Inherit" Size="Size.Small"
                           OnClick="Save" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Size="Size.Small"
                           OnClick="@(() => _isEditing = false)" />
        </MudStack>
    }
    else {
        <MudMenu Label="@signedIn.Name" StartIcon="@Icons.Material.Filled.AccountCircle"
                 Color="Color.Inherit" Dense="true" Class="user-menu">
            <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="StartEdit">Rename</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="SignOut">Sign out</MudMenuItem>
        </MudMenu>
    }
}
else if (_isNaming) {
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
        <MudTextField @bind-Value="_newName" Immediate="true" Margin="Margin.Dense" Placeholder="Your name"
                      Variant="Variant.Outlined" MaxLength="30" Style="width: 12rem" Disabled="@_busy"
                      OnKeyDown="@(e => { if (e.Key == "Enter") CreatePasskey(); })" />
        <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Inherit" Size="Size.Small"
                       Disabled="@(_busy || _newName.Trim().Length == 0)" OnClick="CreatePasskey" />
        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Size="Size.Small"
                       Disabled="@_busy" OnClick="@(() => _isNaming = false)" />
    </MudStack>
}
else {
    <MudMenu Label="Guest" StartIcon="@Icons.Material.Filled.Person"
             Color="Color.Inherit" Dense="true" Disabled="@_busy" Class="user-menu">
        <MudMenuItem Icon="@Icons.Material.Filled.Fingerprint" OnClick="SignIn">Sign in with passkey</MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.PersonAdd" OnClick="StartNaming">Create a passkey</MudMenuItem>
    </MudMenu>
}

@code {
    private bool _isEditing;
    private bool _isNaming;
    private bool _busy;
    private string _editedName = "";
    private string _newName = "";

    protected override void OnInitialized()
        // The edit-mode toggle and busy flag are local state changed via events
        => MustRenderAfterEvent = true;

    protected override async Task<UserFull?> ComputeState(CancellationToken cancellationToken)
    {
        var session = await CircuitHub.SessionResolver.GetSession(cancellationToken);
        return await Users.GetOwn(session, cancellationToken);
    }

    private void StartEdit()
    {
        _editedName = State.ValueOrDefault?.Name ?? "";
        _isEditing = true;
    }

    private void Save()
    {
        _isEditing = false;
        _ = UICommander.Run(new Users_SetName(Session, _editedName));
    }

    private void StartNaming()
    {
        _newName = "";
        _isNaming = true;
    }

    private async Task CreatePasskey()
    {
        if (_newName.Trim().Length == 0)
            return;

        _busy = true;
        try {
            var options = await Auth.GetRegistrationOptions(Session, _newName.Trim());
            var attestation = await Passkey.Register(options);
            var result = await UICommander.Run(new Auth_RegisterPasskey(Session, attestation));
            if (!result.HasError) {
                _isNaming = false;
                Snackbar.Add($"Passkey created — signed in as {result.Value.Name}.", Severity.Success);
            }
        }
        catch (Exception) {
            Snackbar.Add("Passkey creation was cancelled or unavailable.", Severity.Warning);
        }
        finally {
            _busy = false;
        }
    }

    private async Task SignIn()
    {
        _busy = true;
        try {
            var options = await Auth.GetSignInOptions(Session);
            var assertion = await Passkey.Authenticate(options);
            var result = await UICommander.Run(new Auth_SignIn(Session, assertion));
            if (!result.HasError)
                Snackbar.Add($"Signed in as {result.Value.Name}.", Severity.Success);
        }
        catch (Exception) {
            Snackbar.Add("Sign-in was cancelled or no passkey was found.", Severity.Warning);
        }
        finally {
            _busy = false;
        }
    }

    private void SignOut()
        => _ = UICommander.Run(new Auth_SignOut(Session));
}
