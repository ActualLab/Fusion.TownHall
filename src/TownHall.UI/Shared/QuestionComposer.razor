@inherits AppComponentBase
@inject IQuestions Questions
@inject IDialogService DialogService

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudText Typo="Typo.subtitle1" Class="mb-2">Your question</MudText>
    @if (!IsSignedIn) {
        <MudAlert Severity="Severity.Info" Dense="true">Sign in to post a question.</MudAlert>
    }
    else {
        <MudTextField @bind-Value="_text" Immediate="true" Lines="2" MaxLength="500" Counter="500"
                      Placeholder="Type your question here" HelperText="Press Enter to post"
                      Variant="Variant.Outlined" Disabled="@(!IsLive)"
                      OnKeyUp="OnKeyUp" />
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
            <MudCheckBox @bind-Value="_anonymous" Dense="true" Color="Color.Primary" Size="Size.Small"
                         Label="@(AnonName.Length > 0 ? $"Post anonymously as {AnonName}" : "Post anonymously")" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       Disabled="@(!IsLive || _text.Trim().Length == 0)" OnClick="ConfirmAndPost">
                Post
            </MudButton>
        </MudStack>
    }
</MudPaper>

@code {
    private string _text = "";
    private bool _anonymous;

    [Parameter, EditorRequired] public string RoomId { get; set; } = "";
    [Parameter] public bool IsLive { get; set; }
    [Parameter] public bool IsSignedIn { get; set; }
    // The poster's pseudonym for this room, shown next to the "Post anonymously" checkbox.
    [Parameter] public string AnonName { get; set; } = "";

    // On key UP, so the Enter that opens the dialog can't also trigger its default button
    private Task OnKeyUp(KeyboardEventArgs e)
        => e.Key == "Enter" ? ConfirmAndPost() : Task.CompletedTask;

    private async Task ConfirmAndPost()
    {
        // Questions are single-paragraph: line feeds and whitespace runs collapse to single spaces
        var text = string.Join(" ", _text.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
        _text = text;
        if (text.Length == 0)
            return;

        var isConfirmed = await DialogService.ShowMessageBoxAsync(
            "Post this question?", text, yesText: "Post", cancelText: "Keep editing");
        if (isConfirmed != true)
            return;

        var result = await UICommander.Run(() => Questions.Post(new Questions_Post(RoomId, text, _anonymous)));
        if (!result.HasError)
            _text = "";
    }
}
