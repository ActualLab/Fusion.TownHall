@inherits ComputedStateComponent<User>
@inject IUsers Users

@(State.ValueOrDefault?.Name ?? "")

@code {
    [Parameter, EditorRequired] public string UserId { get; set; } = "";

    protected override async Task<User> ComputeState(CancellationToken cancellationToken)
    {
        return await Users.Get(Session, UserId, cancellationToken) ?? User.Guest;
    }
}
