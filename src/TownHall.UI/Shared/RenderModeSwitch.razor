@inject RenderModeHelper RenderModeHelper

<MudMenu Label="@RenderModeHelper.GetCurrentModeTitle()"
         Color="Color.Inherit" Size="Size.Small"
         EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
    @foreach (var mode in RenderModeDef.All) {
        <MudMenuItem OnClick="@(() => RenderModeHelper.ChangeMode(mode))">@mode.Title</MudMenuItem>
    }
</MudMenu>
