@inherits ComputedStateComponent<ParticipantInfo>
@inject IParticipants Participants

@{
    var name = State.ValueOrDefault?.Name ?? "";
}
@if (_isEditing) {
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
        <MudTextField @bind-Value="_editedName" Immediate="true" Margin="Margin.Dense"
                      Variant="Variant.Outlined" MaxLength="30" Style="width: 12rem"
                      OnKeyDown="@(e => { if (e.Key == "Enter") Save(); })" />
        <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Inherit" Size="Size.Small"
                       OnClick="Save" />
        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Size="Size.Small"
                       OnClick="@(() => _isEditing = false)" />
    </MudStack>
}
else {
    <MudButton StartIcon="@Icons.Material.Filled.Person" Color="Color.Inherit"
               OnClick="StartEdit">@name</MudButton>
}

@code {
    private bool _isEditing;
    private string _editedName = "";

    protected override void OnInitialized()
    {
        // The edit-mode toggle is local state changed via events
        MustRenderAfterEvent = true;
    }

    protected override async Task<ParticipantInfo> ComputeState(CancellationToken cancellationToken)
    {
        var session = await CircuitHub.SessionResolver.GetSession(cancellationToken);
        return await Participants.GetOwn(session, cancellationToken);
    }

    private void StartEdit()
    {
        _editedName = State.ValueOrDefault?.Name ?? "";
        _isEditing = true;
    }

    private void Save()
    {
        _isEditing = false;
        _ = UICommander.Run(new Participants_SetName(Session, _editedName));
    }
}
