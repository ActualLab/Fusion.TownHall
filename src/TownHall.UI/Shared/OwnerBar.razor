@using TownHall.UI.Services
@inherits AppComponentBase
@inject IRooms Rooms
@inject ISnackbar Snackbar

<MudPaper Class="pa-3 mb-4" Elevation="2">
    <div class="d-flex align-center" style="cursor: pointer;" @onclick="@(() => _expanded = !_expanded)">
        <MudText Typo="Typo.subtitle1">Owner tools</MudText>
        <MudSpacer />
        <MudIcon Icon="@(_expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" />
    </div>
    @if (_expanded) {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mt-3">
            <MudCheckBox Value="@Room.IsPrivate" T="bool" ValueChanged="SetIsPrivate" Dense="true"
                         Disabled="@IsEnded" Label="Private" />
            <MudSpacer />
            <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.ContentCopy"
                       Disabled="@(_ownerToken == null)"
                       OnClick="CopyOwnerLink">
                Copy owner link
            </MudButton>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-2">
            <MudTextField @bind-Value="_title" Immediate="true" MaxLength="80" Margin="Margin.Dense"
                          Label="Title" Variant="Variant.Outlined" />
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(_title.Trim().Length == 0 || _title.Trim() == Room.Title)"
                       OnClick="Rename">
                Rename
            </MudButton>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-2">
            <MudTextField @bind-Value="_link" Immediate="true" MaxLength="500" Margin="Margin.Dense"
                          Label="Live-event link" Placeholder="https://zoom.us/j/…" Variant="Variant.Outlined" />
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(_link.Trim() == Room.Link)"
                       OnClick="SaveLink">
                Save
            </MudButton>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-2">
            <MudTextField @bind-Value="_description" Immediate="true" Lines="2" MaxLength="1000" Margin="Margin.Dense"
                          Label="Description" Variant="Variant.Outlined" />
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(_description.Trim() == Room.Description)"
                       OnClick="SaveDescription">
                Save
            </MudButton>
        </MudStack>
    }
</MudPaper>

@code {
    private bool _expanded;
    private string _title = "";
    private string _link = "";
    private string _description = "";
    private string? _ownerToken;

    [Parameter, EditorRequired] public Room Room { get; set; } = null!;

    private bool IsEnded => Room.Status == RoomStatus.Ended;

    protected override void OnInitialized()
    {
        _title = Room.Title;
        _link = Room.Link;
        _description = Room.Description;
    }

    protected override async Task OnInitializedAsync()
        // The owner token never changes for a room, so a single fetch is enough
        => _ownerToken = await Rooms.GetOwnerToken(Room.Id);

    private Task SetIsPrivate(bool isPrivate)
        => UICommander.Run(() => Rooms.SetIsPrivate(new Rooms_SetIsPrivate(Room.Id, isPrivate)));

    private Task Rename()
        => UICommander.Run(() => Rooms.SetTitle(new Rooms_SetTitle(Room.Id, _title)));

    private Task SaveLink()
        => UICommander.Run(() => Rooms.SetLink(new Rooms_SetLink(Room.Id, _link)));

    private Task SaveDescription()
        => UICommander.Run(() => Rooms.SetDescription(new Rooms_SetDescription(Room.Id, _description)));

    private async Task CopyOwnerLink()
    {
        // The owner link is never displayed — it goes straight to the clipboard
        if (_ownerToken is not { } token)
            return;

        var url = Nav.ToAbsoluteUri($"/room/{Room.Id}/own/{token}").ToString();
        await JS.InvokeVoidAsync("townHall.copyText", url);
        Snackbar.Add("Owner link copied to clipboard", Severity.Success);
    }
}
