@page "/"
@inherits ComputedStateComponent<HomePage.Model>
@inject IRooms Rooms
@inject IUsers Users
@inject ISnackbar Snackbar

@{
    var isSignedIn = State.ValueOrDefault?.IsSignedIn ?? false;
}

<PageTitle>Town Hall</PageTitle>

<MudText Class="mb-6" Typo="Typo.body1">
    A live-audience Q&amp;A and mood tracker built with
    <MudLink Href="https://github.com/ActualLab/Fusion" Target="_blank" Typo="Typo.body1">Fusion</MudLink>.
    Create a town hall, share its link, and let your audience post and upvote questions while the
    room's mood updates live. The full source is
    <MudLink Href="https://github.com/ActualLab/Fusion.TownHall" Target="_blank" Typo="Typo.body1">on GitHub</MudLink>.
</MudText>

@if (_createdRoom is { } created) {
    <MudPaper Class="pa-4 mb-6" Elevation="3">
        <MudText Typo="Typo.h6" GutterBottom="true">Your town hall is ready 🎉</MudText>
        <MudText Typo="Typo.body2" Class="mb-1">Participant link — share this with your audience:</MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
            <MudTextField Value="@RoomUrl(created.Id)" ReadOnly="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                           OnClick="@(() => Copy(RoomUrl(created.Id), "Participant link"))" />
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/room/{created.Id}")">
                Enter your town hall
            </MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.ContentCopy"
                       OnClick="@(() => Copy(OwnerUrl(created.Id), "Owner link"))">
                Copy owner link
            </MudButton>
        </MudStack>
    </MudPaper>
}
else if (!isSignedIn) {
    <MudPaper Class="pa-4 mb-6" Elevation="3">
        <MudText Typo="Typo.h6" GutterBottom="true">Create a town hall</MudText>
        <MudAlert Severity="Severity.Info" Dense="true">
            Sign in with a passkey (top-right) to create a town hall.
        </MudAlert>
    </MudPaper>
}
else {
    <MudPaper Class="pa-4 mb-6" Elevation="3">
        <MudText Typo="Typo.h6" GutterBottom="true">Create a town hall</MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="_title" Label="Title" Immediate="true" MaxLength="80"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 20rem" />
            <MudSelect @bind-Value="_durationMinutes" Label="Duration" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="width: 8rem">
                <MudSelectItem Value="15">15 min</MudSelectItem>
                <MudSelectItem Value="60">1 h</MudSelectItem>
                <MudSelectItem Value="240">4 h</MudSelectItem>
                <MudSelectItem Value="480">8 h</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_title.Trim().Length == 0)"
                       OnClick="Create">
                Create
            </MudButton>
        </MudStack>
        <MudTextField @bind-Value="_link" Label="Live-event link (optional)" Immediate="true" MaxLength="500"
                      Placeholder="https://zoom.us/j/…" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" />
        <MudTextField @bind-Value="_description" Label="Description (optional)" Immediate="true" Lines="2" MaxLength="1000"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" />
        <MudCheckBox @bind-Value="_isPrivate" Label="Private — hidden from the town hall list below" Dense="true" />
    </MudPaper>
}

<MudText Typo="Typo.h6" GutterBottom="true">Active &amp; recent town halls</MudText>
@if (State.ValueOrDefault is { RoomIds.IsDefault: false } m) {
    var roomIds = m.RoomIds;
    @if (roomIds.Length == 0) {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            No town halls yet — create the first one above!
        </MudText>
    }
    @foreach (var roomId in roomIds) {
        <RoomListRow @key="@roomId" RoomId="@roomId" />
    }
    @if (roomIds.Length >= _limit) {
        <MudButton Class="mt-2" Variant="Variant.Text" Size="Size.Small" OnClick="ShowMore">Show more</MudButton>
    }
}
else {
    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
}

@code {
    private string _title = "";
    private string _link = "";
    private string _description = "";
    private int _durationMinutes = 60;
    private bool _isPrivate;
    private Room? _createdRoom;
    private string? _createdOwnerToken;

    private const int PageSize = 100;
    private int _limit = PageSize;

    protected override void OnInitialized()
    {
        // Local fields (title, post-create panel, etc.) change via events,
        // which don't re-render state-driven components by default
        MustRenderAfterEvent = true;
    }

    protected override async Task<Model> ComputeState(CancellationToken cancellationToken)
    {
        var session = await CircuitHub.SessionResolver.GetSession(cancellationToken);
        var roomIds = await Rooms.ListRooms(session, _limit, cancellationToken);
        var isSignedIn = await Users.GetOwnUserId(session, cancellationToken) != null;
        return new Model(roomIds, isSignedIn);
    }

    // The list is capped at _limit; growing it recomputes the state with a larger page
    private void ShowMore()
    {
        _limit += PageSize;
        _ = State.Recompute();
    }

    private async Task Create()
    {
        var command = new Rooms_Create(
            Session, _title, TimeSpan.FromMinutes(_durationMinutes), _isPrivate, _link, _description);
        var result = await UICommander.Run(command);
        if (result.HasError)
            return;

        _createdRoom = result.Value;
        _createdOwnerToken = await Rooms.GetOwnerToken(Session, result.Value.Id);
        _title = "";
        _link = "";
        _description = "";
    }

    private string RoomUrl(string roomId)
        => Nav.ToAbsoluteUri($"/room/{roomId}").ToString();

    private string OwnerUrl(string roomId)
        => Nav.ToAbsoluteUri($"/room/{roomId}/own/{_createdOwnerToken}").ToString();

    private async Task Copy(string text, string what)
    {
        await JS.InvokeVoidAsync("townHall.copyText", text);
        Snackbar.Add($"{what} copied to clipboard", Severity.Success);
    }

    // Nested types

    public sealed record Model(ImmutableArray<string> RoomIds, bool IsSignedIn);
}
