@inherits StateComponent<ImmutableArray<TrendingQuestion>>
@inject IRoomStats RoomStats

@if (State is { IsDefault: false } rows) {
    @if (rows.Length == 0) {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Nothing's trending right now.</MudText>
    }
    @foreach (var row in rows) {
        <div style="cursor: pointer;" class="mb-2" @key="@row.QuestionIndex"
             @onclick="@(() => JS.InvokeVoidAsync("townHall.scrollTo", $"q-{row.QuestionIndex}"))">
            <MudText Typo="Typo.body2" Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                @row.Text
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Primary">+@row.RecentVoteCount in last 5 min</MudText>
        </div>
    }
}
else {
    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
}

@code {
    [Parameter, EditorRequired] public string RoomId { get; set; } = "";

    protected override object? StateKey => RoomId;

    protected override IAsyncEnumerable<ImmutableArray<TrendingQuestion>> Stream(CancellationToken cancellationToken)
        => RoomStats.ListTrending(RoomId, 5, cancellationToken);
}
