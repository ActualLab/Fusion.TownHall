@inherits StateComponent<UserFull?>
@inject IUsers Users
@inject IAuth Auth
@inject TownHall.UI.Services.PasskeyClient Passkey
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@{
    var user = State;
}
@if (user is { } signedIn) {
    @if (_isEditing) {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
            <MudTextField @bind-Value="_editedName" Immediate="true" Margin="Margin.Dense"
                          Variant="Variant.Outlined" MaxLength="30" Style="width: 12rem"
                          OnKeyDown="@(e => { if (e.Key == "Enter") Save(); })" />
            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Inherit" Size="Size.Small"
                           OnClick="Save" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Size="Size.Small"
                           OnClick="@(() => _isEditing = false)" />
        </MudStack>
    }
    else {
        <MudMenu Label="@signedIn.Name" StartIcon="@Icons.Material.Filled.AccountCircle"
                 Color="Color.Inherit" Dense="true" Class="user-menu">
            <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="StartEdit">Rename</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="SignOut">Sign out</MudMenuItem>
        </MudMenu>
    }
}
else {
    <MudMenu Label="Sign in" StartIcon="@Icons.Material.Filled.Login"
             Color="Color.Inherit" Dense="true" Disabled="@_busy" Class="user-menu">
        <MudMenuItem Icon="@Icons.Material.Filled.Fingerprint" OnClick="SignIn">Sign in with passkey</MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.PersonAdd" OnClick="CreatePasskey">Create a passkey</MudMenuItem>
    </MudMenu>
}

@code {
    private bool _isEditing;
    private bool _busy;
    private string _editedName = "";

    protected override IAsyncEnumerable<UserFull?> Stream(CancellationToken cancellationToken)
        => Users.GetOwn(cancellationToken);

    private void StartEdit()
    {
        _editedName = State?.Name ?? "";
        _isEditing = true;
    }

    private void Save()
    {
        _isEditing = false;
        _ = UICommander.Run(() => Users.SetName(new Users_SetName(_editedName)));
    }

    private async Task CreatePasskey()
    {
        var dialog = await DialogService.ShowAsync<CreatePasskeyDialog>("Create a passkey");
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled)
            return;
        var name = (string)dialogResult.Data!;

        _busy = true;
        try {
            var options = await Auth.GetRegistrationOptions(name);
            var attestation = await Passkey.Register(options);
            var result = await UICommander.Run(() => Auth.RegisterPasskey(new Auth_RegisterPasskey(attestation)));
            if (!result.HasError)
                Snackbar.Add($"Passkey created — signed in as {result.Value!.Name}.", Severity.Success);
        }
        catch (Exception) {
            Snackbar.Add("Passkey creation was cancelled or unavailable.", Severity.Warning);
        }
        finally {
            _busy = false;
        }
    }

    private async Task SignIn()
    {
        _busy = true;
        try {
            var options = await Auth.GetSignInOptions();
            var assertion = await Passkey.Authenticate(options);
            var result = await UICommander.Run(() => Auth.SignIn(new Auth_SignIn(assertion)));
            if (!result.HasError)
                Snackbar.Add($"Signed in as {result.Value!.Name}.", Severity.Success);
        }
        catch (Exception) {
            Snackbar.Add("Sign-in was cancelled or no passkey was found.", Severity.Warning);
        }
        finally {
            _busy = false;
        }
    }

    private void SignOut()
        => _ = UICommander.Run(() => Auth.SignOut());
}
