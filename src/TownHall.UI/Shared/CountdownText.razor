@using TownHall.UI.Services
@implements IDisposable

<style>
    @@keyframes townhall-countdown-blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }
    .townhall-countdown-blink { animation: townhall-countdown-blink 1s ease-in-out infinite; }
</style>

@{
    // While paused the remaining time is frozen at EndsAt - PausedAt; while running it ticks toward EndsAt.
    // A running hall flips to Ended (and this clock is then hidden) at 0, so never show negative time.
    var left = EndsAt - (PausedAt ?? Moment.Now);
    if (left < TimeSpan.Zero)
        left = TimeSpan.Zero;
    var seconds = left.TotalSeconds;
    var color = seconds < 60 ? "var(--mud-palette-error)"    // under a minute: red
        : seconds <= 300 ? "var(--mud-palette-warning)"      // five minutes or less: yellow
        : "";
    // The last 10 seconds of a running countdown flash to grab attention
    var isBlinking = seconds <= 10 && PausedAt == null;
}
<MudText Typo="@Typo" Class="@(isBlinking ? "townhall-countdown-blink" : "")"
         Style="@(color.Length > 0 ? $"color: {color}; font-weight: 700;" : "")">
    @TimeText.Countdown(left) left
</MudText>

@code {
    private System.Threading.Timer? _timer;

    [Parameter] public Moment EndsAt { get; set; }
    [Parameter] public Moment? PausedAt { get; set; }
    [Parameter] public Typo Typo { get; set; } = Typo.h5;

    protected override void OnInitialized()
        // Re-render every second so a running countdown ticks (a paused one stays frozen)
        => _timer = new System.Threading.Timer(_ => _ = InvokeAsync(StateHasChanged), null, 1000, 1000);

    public void Dispose()
        => _timer?.Dispose();
}
