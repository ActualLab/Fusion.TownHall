@page "/room/{RoomId}"
@inherits ComputedStateComponent<RoomPage.Model>
@inject IRooms Rooms
@inject IRoomStats RoomStats
@inject TownHall.UI.Services.LayoutState LayoutState

@{
    var m = State.ValueOrDefault;
}
@if (m == null) {
    <PageTitle>Town Hall</PageTitle>
    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
    return;
}
@if (m.Room is not { } room) {
    <PageTitle>Town Hall</PageTitle>
    <MudAlert Severity="Severity.Warning" Class="mb-4">This town hall doesn't exist.</MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Go home</MudButton>
    return;
}

<PageTitle>@BuildPageTitle(room, m.Stats)</PageTitle>
@{ LayoutState.SetTitle(room.Title); }
<PresenceBeacon RoomId="@RoomId" />

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mb-3">
    <MudChip T="string" Size="Size.Small"
             Color="@(room.Status switch { RoomStatus.Live => Color.Success, RoomStatus.Ended => Color.Error, _ => Color.Default })">
        @room.Status
    </MudChip>
    @if (room.Status != RoomStatus.Paused) {
        <CountdownText ClosesAt="@room.ClosesAt" Typo="Typo.body1" />
    }
    @if (m.IsOwner) {
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@(room.Status == RoomStatus.Ended)"
                   OnClick="@(() => AdjustDuration(-5))">
            −5 min
        </MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                   OnClick="@(() => AdjustDuration(5))">
            +5 min
        </MudButton>
        <MudButton Variant="Variant.Filled" Size="Size.Small"
                   Color="@(room.Status == RoomStatus.Live ? Color.Warning : Color.Success)"
                   Disabled="@(room.Status == RoomStatus.Ended)"
                   OnClick="ToggleLive">
            @(room.Status == RoomStatus.Live ? "Pause" : "Resume")
        </MudButton>
    }
    <MudSpacer />
    <MudText Typo="Typo.body2" Class="mud-text-secondary">
        @m.Stats.AudienceCount @(m.Stats.AudienceCount == 1 ? "participant" : "participants")
    </MudText>
</MudStack>

@if (room.Status == RoomStatus.Paused) {
    <MudAlert Severity="Severity.Info" Class="mb-4">This town hall is paused — hold tight!</MudAlert>
}
else if (room.Status == RoomStatus.Ended) {
    <MudAlert Severity="Severity.Normal" Class="mb-4">This town hall has ended.</MudAlert>
}

@if (m.IsOwner) {
    <OwnerBar Room="@room" />
}

<MudGrid>
    <MudItem xs="12" md="8">
        <QuestionComposer RoomId="@RoomId" IsLive="@(room.Status == RoomStatus.Live)" />
        @if (m.Stats.OpenQuestionCount + m.Stats.ResolvedQuestionCount > 0) {
            <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true">
                <MudTabPanel Text="@($"Top ({m.Stats.OpenQuestionCount})")">
                    <div class="pt-3 px-3 pb-1">
                        <QuestionList RoomId="@RoomId" Tab="QuestionTab.Top" IsOwner="@m.IsOwner"
                                      IsLive="@(room.Status == RoomStatus.Live)" />
                    </div>
                </MudTabPanel>
                <MudTabPanel Text="@($"Recent ({m.Stats.OpenQuestionCount})")">
                    <div class="pt-3 px-3 pb-1">
                        <QuestionList RoomId="@RoomId" Tab="QuestionTab.Recent" IsOwner="@m.IsOwner"
                                      IsLive="@(room.Status == RoomStatus.Live)" />
                    </div>
                </MudTabPanel>
                <MudTabPanel Text="@($"Resolved ({m.Stats.ResolvedQuestionCount})")">
                    <div class="pt-3 px-3 pb-1">
                        <QuestionList RoomId="@RoomId" Tab="QuestionTab.Resolved" IsOwner="@m.IsOwner"
                                      IsLive="@(room.Status == RoomStatus.Live)" />
                    </div>
                </MudTabPanel>
            </MudTabs>
        }
    </MudItem>
    <MudItem xs="12" md="4">
        <MoodPanel RoomId="@RoomId" IsLive="@(room.Status == RoomStatus.Live)" />
        <TrendingPanel RoomId="@RoomId" />
    </MudItem>
</MudGrid>

@code {
    [Parameter] public string RoomId { get; set; } = "";

    protected override async Task<Model> ComputeState(CancellationToken cancellationToken)
    {
        var session = await CircuitHub.SessionResolver.GetSession(cancellationToken);
        var room = await Rooms.Get(session, RoomId, cancellationToken);
        if (room == null)
            return new Model(null, false, new RoomStats(0, 0, 0, 0));

        var isOwner = await Rooms.IsOwner(session, RoomId, cancellationToken);
        var stats = await RoomStats.GetStats(session, RoomId, cancellationToken);
        return new Model(room, isOwner, stats);
    }

    private static string BuildPageTitle(Room room, RoomStats stats)
    {
        var questions = stats.OpenQuestionCount + stats.ResolvedQuestionCount;
        var questionWord = questions == 1 ? "question" : "questions";
        var participantWord = stats.AudienceCount == 1 ? "participant" : "participants";
        return $"Town Hall: {room.Title}, {stats.OpenQuestionCount} open + {stats.ResolvedQuestionCount} resolved "
            + $"{questionWord}, {stats.AudienceCount} {participantWord}";
    }

    private Task AdjustDuration(int minutes)
        => UICommander.Run(new Rooms_AdjustDuration(Session, RoomId, TimeSpan.FromMinutes(minutes)));

    private Task ToggleLive()
        => UICommander.Run(new Rooms_SetLive(Session, RoomId, State.Value.Room!.Status != RoomStatus.Live));

    // Nested types

    public sealed record Model(Room? Room, bool IsOwner, RoomStats Stats);
}
