@using Microsoft.AspNetCore.Components.Web
@using TownHall.Host
@using TownHall.UI
@using TownHall.UI.Services

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Town Hall</title>
    <base href="/" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["_content/MudBlazor/MudBlazor.min.css"]" />
    <ImportMap />
    <link rel="icon" type="image/ico" href="favicon.ico" />
    <HeadOutlet @rendermode="@(_renderMode.Mode)" />
</head>
<body>
    <App @rendermode="@(_renderMode.Mode)"
         SessionId="@_sessionId"
         RenderModeKey="@(_renderMode.Key)" />
    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">🗙</span>
    </div>
    <script>
        window.townHall = {
            copyText: function (text) {
                return navigator.clipboard.writeText(text);
            },
            scrollTo: function (id) {
                document.getElementById(id)?.scrollIntoView({ behavior: "smooth", block: "center" });
            }
        };
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["_content/MudBlazor/MudBlazor.min.js"]"></script>
</body>
</html>

@code {
    private RenderModeDef _renderMode = RenderModeDef.Default;
    private string _sessionId = "";

    [Inject] private IWebHostEnvironment Env { get; init; } = null!;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = null!;

    protected override void OnInitialized()
    {
        // Render mode comes from the cookie the /render-mode switch endpoint sets
        var cookieMode = HttpContext.Request.Cookies.TryGetValue("RenderMode", out var m) ? m : "";
        _renderMode = RenderModeDef.GetOrDefault(cookieMode);

        // Session for the server/auto render modes: a ?session= override (disabled in Production) else
        // the session id the cookie middleware resolved (in HttpContext.Items - present even on the
        // first request, when the cookie is only in the response), falling back to the request cookie.
        var sessionOverride = Env.IsProduction() ? "" : HttpContext.Request.Query["session"].ToString();
        var fromItems = HttpContext.Items.TryGetValue(TownHallHub.SessionCookieName, out var it) ? it as string : null;
        _sessionId = sessionOverride.Length >= 8
            ? sessionOverride
            : fromItems is { Length: >= 8 } ? fromItems
            : HttpContext.Request.Cookies.TryGetValue(TownHallHub.SessionCookieName, out var s) ? s : "";
    }
}
