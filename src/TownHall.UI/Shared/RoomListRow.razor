@using TownHall.UI.Services
@inherits StateComponent<RoomCard?>
@inject IRooms Rooms

@{
    var m = State;
    if (m?.Room is not { } room)
        return;
    var questionCount = m.QuestionCount;
}

<MudPaper Class="pa-3 mb-2" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
        <MudLink Href="@($"/room/{room.Id}")" Typo="Typo.subtitle1">@room.Title</MudLink>
        <MudChip T="string" Size="Size.Small"
                 Color="@(room.Status switch { RoomStatus.Live => Color.Success, RoomStatus.Ended => Color.Error, _ => Color.Default })">
            @room.Status
        </MudChip>
        <MudSpacer />
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@TimeLabel(room)</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            @questionCount @(questionCount == 1 ? "question" : "questions")
            · @m.AudienceCount here
            · mood @MoodEmoji(m.AverageMood)
        </MudText>
    </MudStack>
</MudPaper>

@code {
    private static readonly string[] Emojis = ["😞", "🙁", "😐", "🙂", "😄"];

    [Parameter, EditorRequired] public string RoomId { get; set; } = "";

    protected override object? StateKey => RoomId;

    protected override IAsyncEnumerable<RoomCard?> Stream(CancellationToken cancellationToken)
        => Rooms.GetCard(RoomId, cancellationToken);

    private static string TimeLabel(Room room)
        => room.Status == RoomStatus.Ended ? "ended" : TimeText.Left(room.EndsAt - (room.PausedAt ?? Moment.Now));

    private static string MoodEmoji(double? average)
        => average is { } a ? Emojis[Math.Clamp((int)Math.Round(a), 1, 5) - 1] : "—";
}
