@inherits ComputedStateComponent<string>
@inject IParticipants Participants

@(State.ValueOrDefault ?? "")

@code {
    [Parameter, EditorRequired] public string ParticipantId { get; set; } = "";

    protected override async Task<string> ComputeState(CancellationToken cancellationToken)
        => await Participants.GetName(ParticipantId, cancellationToken);
}
